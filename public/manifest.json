{
  "name": "Smriti",
  "short_name": "Smriti",
  "description": "AI knowledge ingestion — save links, media and files from anywhere.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#4f46e5",
  "orientation": "portrait-primary",
  "lang": "en",
  "icons": [
    {
      "src": "/logo/dark_logo.png",
      "sizes": "any",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo/dark_logo.png",
      "sizes": "any",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": [
            "image/*",
            "video/*",
            "audio/*",
            "application/pdf"
          ]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "Add Link",
      "short_name": "Add",
      "description": "Add a new link to Smriti",
      "url": "/?action=add",
      "icons": [{ "src": "/logo/dark_logo.png", "sizes": "any" }]
    }
  ],
  "screenshots": [],
  "categories": ["productivity", "utilities"],
  "prefer_related_applications": false
}
